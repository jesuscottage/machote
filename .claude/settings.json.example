{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import sys,json; d=json.load(sys.stdin); c=d.get('tool_input',{}).get('command',''); blocked=['rm -rf /','drop table','truncate table','format c','del /s /q']; r=2 if any(b in c.lower() for b in blocked) else 0; r and print('BLOCKED: destructive command detected',file=sys.stderr); sys.exit(r)\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat .claude/context/reminders.md 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
